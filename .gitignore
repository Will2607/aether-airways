# ─── Dependencies ────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js build output ────────────────────────────────────────────────────
/.next/
/out/
/build

# ─── Environment variables ───────────────────────────────────────────────────
# Never commit real env files. Use .env.example as the reference template.
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env.staging.local

# ─── Secrets & certificates ──────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
*.p8
secrets/
credentials/
private/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log.*

# ─── Testing & coverage ──────────────────────────────────────────────────────
/coverage
/playwright-report
/test-results
/.nyc_output

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── OS generated files ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# ─── IDE & editor configs (personal, not shared) ─────────────────────────────
# VSCode: share recommended extensions & settings, not personal workspace state
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*.suo
*.user
*.userosscache
*.sln.docstates
.history/

# ─── Vercel ──────────────────────────────────────────────────────────────────
.vercel

# ─── Misc ────────────────────────────────────────────────────────────────────
*.tgz
*.zip
*.tar.gz
.cache/
.turbo/
