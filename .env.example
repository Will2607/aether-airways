# ─────────────────────────────────────────────────────────────────────────────
# AetherAirways — Environment Variables
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env.local
#   2. Fill in the values for your environment.
#   3. NEVER commit .env.local or any file containing real secrets.
#
# NAMING RULES:
#   NEXT_PUBLIC_*   → Exposed to the browser. Do NOT put secrets here.
#   (no prefix)     → Server-side only. Safe for secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────────────────────

# Display name of the application (used in metadata, emails, etc.)
NEXT_PUBLIC_APP_NAME="AetherAirways"

# Public-facing URL of the deployed app (no trailing slash)
# Local:       http://localhost:3000
# Production:  https://aether-airways.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── API ─────────────────────────────────────────────────────────────────────

# Base URL of the backend REST API (no trailing slash)
# This is exposed to the browser — do NOT include secrets in API calls made here.
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# ─── Authentication ───────────────────────────────────────────────────────────
# (server-side only — never use NEXT_PUBLIC_ for these)

# Secret used to sign JWT tokens. Must be at least 32 random characters.
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Session duration in seconds (default: 7 days)
AUTH_SESSION_EXPIRY=604800

# ─── Database ────────────────────────────────────────────────────────────────
# (server-side only)

# Full connection string for the primary database
# Examples:
#   PostgreSQL: postgresql://user:password@localhost:5432/aether_airways
#   SQLite:     file:./dev.db
DATABASE_URL=""

# ─── Email (Transactional) ────────────────────────────────────────────────────
# (server-side only)

SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="no-reply@aether-airways.com"

# ─── Payments (Stripe) ───────────────────────────────────────────────────────
# (server-side only — NEVER expose secret key to the browser)

# Publishable key — safe to use client-side
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Secret key — server-side only
STRIPE_SECRET_KEY=""

# Webhook signing secret (from Stripe dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=""

# ─── Analytics ───────────────────────────────────────────────────────────────

# Google Analytics measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# ─── Monitoring & Error tracking ─────────────────────────────────────────────

NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ─── Testing ─────────────────────────────────────────────────────────────────

# Base URL Playwright uses for end-to-end tests
PLAYWRIGHT_BASE_URL="http://localhost:3000"
